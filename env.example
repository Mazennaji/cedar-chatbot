CEDAR_MODEL=facebook/blenderbot-400M-distill
CEDAR_DEVICE=cpu                    # cpu or cuda

CEDAR_CORS_ORIGINS=*
CEDAR_RATE_LIMIT=60
CEDAR_AUTH_ENABLED=false
